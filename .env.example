# ============================================================
# AI Provider Keys - fill in at least ONE
# ============================================================

# OpenAI (blocked in China - needs proxy or use DeepSeek instead)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Claude / Anthropic (blocked in China - needs proxy)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# DeepSeek (accessible in China directly - RECOMMENDED for China users)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Default provider: openai / claude / deepseek / ollama
# China users: set this to "deepseek"
AI_DEFAULT_PROVIDER=deepseek

# ============================================================
# Proxy for OpenAI/Claude (China users)
# If you use Clash/V2Ray, set the local port here
# Common ports: 7890 (Clash), 10808 (V2Ray), 1080 (general)
# ============================================================
# HTTP_PROXY_URL=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ============================================================
# Database (optional - history storage)
# ============================================================
DB_PASSWORD=cmdgen123

# ============================================================
# Security
# ============================================================
JWT_SECRET=your-random-jwt-secret-min-32-chars

# ============================================================
# Monitoring (optional)
# ============================================================
GRAFANA_PASSWORD=admin123
